{
    "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "includes": ["**", "!!**/dist", "!**/*.css"]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100,
        "lineEnding": "lf"
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "suspicious": {
                "noExplicitAny": "warn"
            },
            "style": {
                "noNonNullAssertion": "off"
            },
            "complexity": {
                "noStaticOnlyClass": "off"
            },
            "correctness": {
                "useExhaustiveDependencies": "off"
            },
            "a11y": {
                "useButtonType": "off",
                "noLabelWithoutControl": "off",
                "noSvgWithoutTitle": "off",
                "noStaticElementInteractions": "off"
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "jsxQuoteStyle": "double"
        }
    },
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": "off"
            }
        }
    },
    "overrides": [
        {
            "includes": ["**/binary-engine.test.ts"],
            "formatter": { "enabled": false }
        }
    ]
}
